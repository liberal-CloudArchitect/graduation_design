                    ],
                    "index": 2
                },
                {
                    "bbox": [
                        69,
                        361,
                        525,
                        727
                    ],
                    "type": "list",
                    "angle": 0,
                    "index": 6,
                    "blocks": [
                        {
                            "bbox": [
                                69,
